# PostgreSQL (used by Docker Compose and Prisma)
POSTGRES_USER=spopi
POSTGRES_PASSWORD=spopi
POSTGRES_DB=spopi
POSTGRES_PORT=5432

# Prisma connection string (api service)
DATABASE_URL=postgresql://spopi:spopi@postgres:5432/spopi

# API (Express)
API_PORT=4000
API_HOST=0.0.0.0

# Web (Next.js) — browser calls API on host machine port
NEXT_PUBLIC_API_URL=http://localhost:4000
WEB_PORT=3000

# Spotify public metadata (Client Credentials — no user login)
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
